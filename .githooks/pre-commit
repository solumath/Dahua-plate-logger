#!/bin/sh
set -e

echo "==> gofmt"
unformatted=$(gofmt -l ./internal/ ./cmd/ main.go)
if [ -n "$unformatted" ]; then
  echo "FAIL: files need formatting (run gofmt -w):"
  echo "$unformatted"
  exit 1
fi

echo "==> go vet"
go vet ./internal/... ./cmd/... .

echo "==> tests"
go test ./internal/...

echo "OK"
